# ===================================
# ZeroTrust-ID-Governance 環境変数テンプレート
# コピーして .env として使用してください
# .env は git 管理外です（secrets 保護）
# ===================================

# --- アプリケーション ---
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here
APP_DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# --- データベース ---
DATABASE_URL=postgresql://admin:password@localhost:5432/zerotrust_id
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zerotrust_id
DB_USER=admin
DB_PASSWORD=change-me-in-production

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Azure / Microsoft Entra ID ---
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# --- Active Directory ---
AD_SERVER=ldaps://dc01.mirai.local
AD_BIND_DN=CN=ServiceAccount,OU=ServiceAccounts,DC=mirai,DC=local
AD_BIND_PASSWORD=change-me
AD_BASE_DN=DC=mirai,DC=local

# --- HENGEONE ---
HENGEONE_SCIM_BASE_URL=https://api.hengeone.com/scim/v2
HENGEONE_API_TOKEN=your-api-token
HENGEONE_TENANT_ID=your-tenant-id

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- メール通知 ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@mirai-kensetsu.co.jp
SMTP_PASSWORD=change-me

# --- フロントエンド ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ZeroTrust ID Governance
